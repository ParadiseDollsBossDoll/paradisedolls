APP_NAME="Paradise Dolls"
APP_ENV=production
APP_KEY=CHANGE_ME_generate_with_php_artisan_key_generate_show
APP_DEBUG=false
APP_URL=https://yourdomain.tld

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
TRANSLATION_ENABLED=false
TRANSLATION_PROVIDER=google
GOOGLE_TRANSLATE_API_KEY=CHANGE_ME_google_cloud_translation_api_key
TRANSLATION_CACHE_TTL=604800
TRANSLATION_TIMEOUT=10
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXXX
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
BCRYPT_ROUNDS=12
TRUSTED_PROXIES=127.0.0.1

LOG_CHANNEL=daily
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=paradisedollz
DB_USERNAME=paradisedollz_user
DB_PASSWORD=CHANGE_ME_strong_db_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=yourdomain.tld
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=redis
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=resend
