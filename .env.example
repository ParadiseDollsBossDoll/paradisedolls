APP_NAME="Paradise Dolls"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Production hardening: APP_ENV=production, APP_DEBUG=false, HTTPS APP_URL, SESSION_SECURE_COOKIE=true,
# run php artisan config:cache route:cache view:cache, keep APP_KEY secret, and run composer audit regularly.

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Comma-separated proxy IPs/CIDRs, or * (only behind your load balancer). Enables correct HTTPS/client IP when proxied.
# TRUSTED_PROXIES=127.0.0.1
# TRUSTED_PROXIES=*

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: transactional (Resend recommended) - https://resend.com/api-keys
# 1. Create RESEND_API_KEY in the Resend dashboard.
# 2. Add & verify your domain in Resend, then set MAIL_FROM to e.g. noreply@yourdomain.com.
# Until a domain is verified, Resend allows onboarding@resend.dev for testing (see Resend docs).
MAIL_MAILER=resend
# REQUIRED when MAIL_MAILER=resend - paste full key from https://resend.com/api-keys (starts with re_)
RESEND_API_KEY=

MAIL_FROM_ADDRESS="onboarding@resend.dev"
MAIL_FROM_NAME="${APP_NAME}"

# Local / alternative: log (storage/logs/laravel.log) or SMTP (Gmail requires App Password).
# MAIL_MAILER=log
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM_ADDRESS=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel Reverb (WebSockets for community chat real-time)
# Run: php artisan reverb:install  then set these keys.
REVERB_APP_ID=your-app-id
REVERB_APP_KEY=your-app-key
REVERB_APP_SECRET=your-app-secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Community chat performance / tuning
COMMUNITY_PERFORMANCE_ENABLED=false
COMMUNITY_PERFORMANCE_LOG_CHANNEL=community-performance
COMMUNITY_SLOW_QUERY_MS=150
COMMUNITY_SLOW_REQUEST_MS=800
COMMUNITY_INITIAL_MESSAGE_PAGE_SIZE=15
COMMUNITY_MESSAGE_PAGE_SIZE=25
COMMUNITY_MESSAGE_SYNC_LIMIT=50
COMMUNITY_READ_MARK_CHUNK_SIZE=250
COMMUNITY_SEARCH_MIN_CHARS=2
COMMUNITY_SEARCH_PREVIEW_LIMIT=8
COMMUNITY_IMAGE_PREVIEW_MAX_BYTES=4194304
COMMUNITY_PRESENCE_CACHE_STORE=file
COMMUNITY_PRESENCE_REFRESH_INTERVAL_MS=30000

PARADISE_ONBOARDING_EMAIL="admin@getrichwithparadisedolls.com"
PARADISE_COMMUNITY_URL="https://discord.gg/paradisedolls"
PARADISE_COMMUNITY_ROLE_NAME="Boss Doll Blueprint"

# Bunny Stream (video hosting for LMS lessons)
# Create a library at bunny.net → Stream, then paste ID and API key here.
BUNNY_LIBRARY_ID=
BUNNY_API_KEY=
# CDN hostname from the library settings (e.g. vz-xxxxxx.b-cdn.net)
BUNNY_CDN_HOSTNAME=
# How long (seconds) upload auth signatures remain valid — default 24h
BUNNY_UPLOAD_SIGNATURE_TTL=86400
