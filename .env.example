# =============================================================================
# Paradise Dolls — Local Development Environment Template
# =============================================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Run:             php artisan key:generate
#   3. Fill in every value marked FILL_IN (ask the project lead for secrets)
# Never put real secrets in this file — it is committed to git.
# =============================================================================

APP_NAME="Paradise Dolls"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
# Port 3307 = local XAMPP default. Change to 3306 for a standard MySQL install.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=paradisedollz
DB_USERNAME=root
DB_PASSWORD=

# ── Session / Cache / Queue ───────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# ── Redis (not required for local dev — file/sync drivers are used above) ─────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ──────────────────────────────────────────────────────────────────────
# "log" driver writes emails to storage/logs/laravel.log — no real sending.
# Switch to "resend" and fill in RESEND_API_KEY to send real emails locally.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@paradisedolls.local"
MAIL_FROM_NAME="${APP_NAME}"

# MAIL_MAILER=resend
# RESEND_API_KEY=FILL_IN

# ── Laravel Reverb (WebSockets) ───────────────────────────────────────────────
# Run `php artisan reverb:start` to start the local WebSocket server.
# Ask the project lead for the REVERB_APP_SECRET value.
REVERB_APP_ID=318170
REVERB_APP_KEY=h1x6i3o9e5u7bdlxzfy2
REVERB_APP_SECRET=FILL_IN
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── Community Chat ─────────────────────────────────────────────────────────────
COMMUNITY_PERFORMANCE_ENABLED=false
COMMUNITY_INITIAL_MESSAGE_PAGE_SIZE=15
COMMUNITY_MESSAGE_PAGE_SIZE=20
COMMUNITY_MESSAGE_SYNC_LIMIT=30
COMMUNITY_PRESENCE_CACHE_STORE=file
COMMUNITY_PRESENCE_REFRESH_INTERVAL_MS=45000
COMMUNITY_READ_MARK_CHUNK_SIZE=100

# ── Paradise Dolls Business Config ────────────────────────────────────────────
PARADISE_ONBOARDING_EMAIL="admin@getrichwithparadisedolls.com"
PARADISE_COMMUNITY_URL="https://discord.gg/paradisedolls"
PARADISE_COMMUNITY_ROLE_NAME="Boss Doll Blueprint"

# ── BunnyCDN (video hosting) ───────────────────────────────────────────────────
# Ask the project lead for the BUNNY_API_KEY — it controls the video library.
BUNNY_LIBRARY_ID=654926
BUNNY_API_KEY=FILL_IN
BUNNY_CDN_HOSTNAME=vz-049511ff-031.b-cdn.net
BUNNY_UPLOAD_SIGNATURE_TTL=86400
